MONGO_URI=mongodb://127.0.0.1:27017/easemessage
JWT_SECRET=replace_with_jwt_secret
PORT=3301

# Public app URLs
FRONTEND_URL=http://localhost:3300
PUBLIC_SERVER_URL=http://localhost:3301
PUBLIC_API_URL=http://localhost:3301/api

# Webhook URLs for Stripe / Razorpay / Meta
STRIPE_WEBHOOK_URL=http://localhost:3301/api/billing/webhooks/stripe
RAZORPAY_WEBHOOK_URL=http://localhost:3301/api/billing/webhooks/razorpay
WHATSAPP_WEBHOOK_URL=http://localhost:3301/api/whatsapp/webhook
WEBHOOK_VERIFY_TOKEN=replace_with_meta_verify_token

# Billing providers
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
RAZORPAY_KEY_ID=rzp_test_replace
RAZORPAY_KEY_SECRET=replace
RAZORPAY_WEBHOOK_SECRET=replace

# Optional ngrok token
NGROK_AUTHTOKEN=optional_ngrok_auth_token

# SMTP
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_smtp_password
ENTERPRISE_REQUEST_EMAIL=lakhendra@easexpense.com

# Stripe price IDs
